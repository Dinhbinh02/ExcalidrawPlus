{
  "manifest_version": 3,
  "name": "Excalidraw+",
  "version": "1.0",
  "description": "Enhances Excalidraw with additional features, localized font support, and seamless Google Drive project synchronization.",
  "permissions": [
    "declarativeNetRequest",
    "identity",
    "storage"
  ],
  "host_permissions": [
    "https://excalidraw.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "key": "",
  "oauth2": {
    "client_id": "824888142961-rl8p766vurc40cls3cuaabd0vj16j804.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile",
      "https://www.googleapis.com/auth/drive.appdata"
    ]
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://excalidraw.com/*"],
      "css": ["content.css", "ai_assistant.css"],
      "js": ["content.js", "ai_assistant.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["fonts/*"],
      "matches": ["https://excalidraw.com/*"]
    }
  ]
}
